# Copia este archivo como bridge/.env y llena tus credenciales reales
YUNATT_EMAIL=tu-correo@ejemplo.com
YUNATT_PASSWORD=tu-password-de-yunatt

# Base de datos MySQL (opcional — si se deja vacío usa localhost/root/sin
# password/erp_lost_children, igual que antes). Centralizado acá para no
# tener que tocar 6+ archivos si alguna vez se protege MySQL con password
# o se apunta a un host distinto.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=erp_lost_children

# TLS del servidor Flask (bridge/ssl/cert.pem + key.pem).
#   auto  -> se activa solo si el certificado existe (default)
#   true  -> exige TLS, falla a HTTP con warning si falta el certificado
#   false -> fuerza HTTP plano aunque el certificado exista
# Solo aplica cuando se corre con `python bridge/server.py` (dev en Windows).
# Bajo Docker/gunicorn, docker-entrypoint.sh decide el TLS por su cuenta
# según si hay certificado montado en bridge/ssl/ — ver docker-compose.yml.
ENABLE_TLS=auto

# Orígenes adicionales para CORS, separados por coma (localhost/127.0.0.1 ya
# están permitidos por defecto). Necesario en producción para que el
# navegador no bloquee las llamadas del frontend por CORS — p.ej. la IP
# pública del servidor: CORS_ORIGINS=https://80.190.76.84:8443
CORS_ORIGINS=
