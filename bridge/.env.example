# Copia este archivo como bridge/.env y llena tus credenciales reales
YUNATT_EMAIL=tu-correo@ejemplo.com
YUNATT_PASSWORD=tu-password-de-yunatt

# Base de datos MySQL (opcional — si se deja vacío usa localhost/root/sin
# password/erp_lost_children, igual que antes). Centralizado acá para no
# tener que tocar 6+ archivos si alguna vez se protege MySQL con password
# o se apunta a un host distinto.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=erp_lost_children
